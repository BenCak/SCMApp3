@page "/system-versions/{SystemVersionId:int}/segments"
@inject ApiService Api

<PageTitle>Segments</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />
<MudText Typo="Typo.h5" GutterBottom="true">Segments</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_segments" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Released</MudTh>
            <MudTh>POC</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.VersionNumber</MudTd>
            <MudTd>
                <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>@context.ReleasedDate?.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@context.PocName</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/segments/{context.Id}/cscis?segmentName={Uri.EscapeDataString(context.Name)}&versionName={Uri.EscapeDataString(VersionName ?? "")}&systemName={Uri.EscapeDataString(SystemName ?? "")}")">
                    CSCIs
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int SystemVersionId { get; set; }
    [SupplyParameterFromQuery] public string? VersionName { get; set; }
    [SupplyParameterFromQuery] public string? SystemName { get; set; }

    private List<SegmentDto> _segments = [];
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Systems", href: "/systems"),
            new BreadcrumbItem(SystemName ?? "System", href: null, disabled: true),
            new BreadcrumbItem(VersionName ?? $"Version #{SystemVersionId}", href: null, disabled: true),
            new BreadcrumbItem("Segments", href: null, disabled: true)
        ];

        _segments = await Api.GetSegmentsAsync(SystemVersionId);
        _loading = false;
    }

    private static Color StatusColor(string status) => status switch
    {
        "Released"    => Color.Success,
        "InReview"    => Color.Info,
        "Pending"     => Color.Warning,
        "Rejected"    => Color.Error,
        "NeedMoreInfo"=> Color.Warning,
        _             => Color.Default
    };
}
