@page "/customers"
@inject ApiService Api
@inject IDialogService DialogService

<PageTitle>Customers</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <MudText Typo="Typo.h5">Customers</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">
        Add Customer
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_customers" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Abbreviation</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.Abbreviation</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context))" />
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/systems?customerId={context.Id}&customerName={Uri.EscapeDataString(context.Name)}")">
                    View Systems
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<CustomerDto> _customers = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _customers = await Api.GetCustomersAsync();
        _loading = false;
    }

    private async Task OpenAddDialog()
    {
        var dialog = await DialogService.ShowAsync<AddCustomerDialog>("Add Customer");
        var result = await dialog.Result;
        if (result is { Canceled: false }) await Load();
    }

    private async Task OpenEditDialog(CustomerDto customer)
    {
        var parameters = new DialogParameters { ["Customer"] = customer };
        var dialog = await DialogService.ShowAsync<EditCustomerDialog>("Edit Customer", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await Load();
    }
}
