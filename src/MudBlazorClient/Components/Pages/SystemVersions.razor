@page "/systems/{SystemId:int}/versions"
@inject ApiService Api

<PageTitle>System Versions</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />
<MudText Typo="Typo.h5" GutterBottom="true">System Versions</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_versions" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Version</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Released</MudTh>
            <MudTh>POC</MudTh>
            <MudTh>SVD Path</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.VersionNumber</MudTd>
            <MudTd>
                <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>@context.ReleasedDate?.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@context.PocName</MudTd>
            <MudTd>@context.SvdPath</MudTd>
            <MudTd>
                <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                           Href="@($"/system-versions/{context.Id}/segments?versionName={Uri.EscapeDataString(context.VersionNumber)}&systemName={Uri.EscapeDataString(SystemName ?? "")}")">
                    Segments
                </MudButton>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int SystemId { get; set; }
    [SupplyParameterFromQuery] public string? SystemName { get; set; }

    private List<SystemVersionDto> _versions = [];
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Systems", href: "/systems"),
            new BreadcrumbItem(SystemName ?? $"System #{SystemId}", href: null, disabled: true),
            new BreadcrumbItem("Versions", href: null, disabled: true)
        ];

        _versions = await Api.GetSystemVersionsAsync(SystemId);
        _loading = false;
    }

    private static Color StatusColor(string status) => status switch
    {
        "Released"    => Color.Success,
        "InReview"    => Color.Info,
        "Pending"     => Color.Warning,
        "Rejected"    => Color.Error,
        "NeedMoreInfo"=> Color.Warning,
        _             => Color.Default
    };
}
