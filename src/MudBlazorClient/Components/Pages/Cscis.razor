@page "/segments/{SegmentId:int}/cscis"
@inject ApiService Api

<PageTitle>CSCIs</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-2 pa-0" />
<MudText Typo="Typo.h5" GutterBottom="true">CSCIs</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_cscis" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Version</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Released</MudTh>
            <MudTh>Charge #</MudTh>
            <MudTh>Release Location</MudTh>
            <MudTh>POC</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@context.VersionNumber</MudTd>
            <MudTd>
                <MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>@context.ReleasedDate?.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@context.ChargeNumber</MudTd>
            <MudTd>@context.ReleaseLocation</MudTd>
            <MudTd>@context.PocName</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Parameter] public int SegmentId { get; set; }
    [SupplyParameterFromQuery] public string? SegmentName { get; set; }
    [SupplyParameterFromQuery] public string? VersionName { get; set; }
    [SupplyParameterFromQuery] public string? SystemName { get; set; }

    private List<CsciDto> _cscis = [];
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/"),
            new BreadcrumbItem("Systems", href: "/systems"),
            new BreadcrumbItem(SystemName ?? "System", href: null, disabled: true),
            new BreadcrumbItem(VersionName ?? "Version", href: null, disabled: true),
            new BreadcrumbItem(SegmentName ?? $"Segment #{SegmentId}", href: null, disabled: true),
            new BreadcrumbItem("CSCIs", href: null, disabled: true)
        ];

        _cscis = await Api.GetCscisAsync(SegmentId);
        _loading = false;
    }

    private static Color StatusColor(string status) => status switch
    {
        "Released"    => Color.Success,
        "InReview"    => Color.Info,
        "Pending"     => Color.Warning,
        "Rejected"    => Color.Error,
        "NeedMoreInfo"=> Color.Warning,
        _             => Color.Default
    };
}
