@inject ApiService Api
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_valid">
            <MudSelect T="int" @bind-Value="_customerId" Label="Customer" Required="true"
                       RequiredError="Customer is required">
                @foreach (var c in _customers)
                {
                    <MudSelectItem T="int" Value="@c.Id">@c.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="int" @bind-Value="_productId" Label="Product" Required="true"
                       RequiredError="Product is required" Class="mt-3">
                @foreach (var p in _products)
                {
                    <MudSelectItem T="int" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>

            <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1">Point of Contact</MudText>
            <MudTextField @bind-Value="_pocName" Label="Name" Class="mt-2" />
            <MudTextField @bind-Value="_pocEmail" Label="Email" InputType="InputType.Email" Class="mt-3" />
            <MudTextField @bind-Value="_pocPhone" Label="Phone" Class="mt-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;
    private bool _valid;
    private bool _saving;

    private List<CustomerDto> _customers = [];
    private List<ProductDto> _products = [];

    private int _customerId;
    private int _productId;
    private string? _pocName;
    private string? _pocEmail;
    private string? _pocPhone;

    protected override async Task OnInitializedAsync()
    {
        var customersTask = Api.GetCustomersAsync();
        var productsTask = Api.GetProductsAsync();
        await Task.WhenAll(customersTask, productsTask);
        _customers = customersTask.Result;
        _products = productsTask.Result;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_valid) return;

        _saving = true;
        var ok = await Api.CreateSystemAsync(_customerId, _productId, _pocName, _pocEmail, _pocPhone);
        _saving = false;

        if (ok)
            MudDialog.Close(DialogResult.Ok(true));
        else
            Snackbar.Add("Failed to save system.", Severity.Error);
    }
}
